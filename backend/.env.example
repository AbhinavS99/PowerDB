# Azure SQL connection
DATABASE_URL=mssql+aioodbc://powerdbadmin:YOUR_PASSWORD@powerdb-sqlserver.database.windows.net:1433/powerdb?driver=ODBC+Driver+18+for+SQL+Server

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (local dev + deployed frontend)
FRONTEND_URL=http://localhost:5173
